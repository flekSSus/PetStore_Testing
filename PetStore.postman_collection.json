        "exec": [
          "const VALID_ENV_NAMES = [\"PetStore\"];",
          "const REQUIRED_VAR_1 = \"BaseUrl\";  ",
          "",
          "const currentEnvName = pm.environment.name;",
          "const value_1 = pm.environment.get(REQUIRED_VAR_1);",
          "",
          "if (!currentEnvName) {",
          "    throw new Error(\"Не выбрано окружение. Выберите окружение в Postman.\");",
          "}",
          "",
          "if (!VALID_ENV_NAMES.includes(currentEnvName)) {",
          "    throw new Error(`Окружение \"${currentEnvName}\" не разрешено. Разрешены: ${EXPECTED_ENV_NAMES.join(\", \")}`);",
          "}",
          "",
          "if (!value_1) {",
          "    throw new Error(` В окружении \"${currentEnvName}\" отсутствует  переменная \"${REQUIRED_VAR_1}\" .`);",
          "}",
          "",
          "console.log(`Окружение \"${currentEnvName}\" содержит переменную \"${REQUIRED_VAR_1}\": ${value_1}`);"
        ]
      }
