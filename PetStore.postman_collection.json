        {
          "name": "Create Pet",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const newPetId = Math.floor(Math.random() * 100) + 1;",
                  "pm.environment.set(\"petId\", newPetId);",
                  "",
                  "const petName = \"Pet_\" + newPetId;",
                  "pm.environment.set(\"petName\", petName);",
                  "",
                  "console.log(`Создан питомец: ID=${newPetId}, имя=${petName}`);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has id\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"id\");",
                  "",
                  "});",
                  "",
                  "pm.test(\"Name matches request\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var requestBody = pm.request.body.raw;",
                  "    var requestData = JSON.parse(requestBody);",
                  "    pm.expect(jsonData.name).to.eql(requestData.name);",
                  "});",
                  "",
                  "pm.test(\"Content-Type = application/json\", () => {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "});",
                  "",
                  "const Ajv = require('ajv');",
                  "const ajv = new Ajv({ allErrors: true });",
                  "",
                  "const petSchema = {",
                  "  \"id\": 1,",
                  "  \"name\": \"{{petName}}\",",
                  "  \"category\": {",
                  "    \"id\": 1,",
                  "    \"name\": \"Cats\"",
                  "  },",
                  "  \"photoUrls\": [",
                  "    \"string\"",
                  "  ],",
                  "  \"tags\": [",
                  "    {",
                  "      \"id\": 1,",
                  "      \"name\": \"string\"",
                  "    }",
                  "  ],",
                  "  \"status\": \"available\"",
                  "};",
                  "",
                  "pm.test(\"Valid JSON response\", () => {",
                  "  const valid = ajv.validate(petSchema, pm.response.json());",
                  "  pm.expect(valid).to.be.true;",
                  "  if (!valid) console.log(ajv.errors);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
